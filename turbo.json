{
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "PORT",
    "WS_PORT",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "MM_MARKETS",
    "MM_LOOP_INTERVAL_MS",
    "MM_LEVELS",
    "MM_BASE_PRICE",
    "MM_BASE_QUANTITY",
    "MM_SPREAD_BPS",
    "MM_LEVEL_SPACING_BPS",
    "MM_REPRICE_TOLERANCE_BPS",
    "MM_JITTER_BPS",
    "MM_TARGET_BASE_RATIO",
    "MM_MAX_INVENTORY_SKEW_BPS",
    "OPERATOR_EMAILS",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "^db:generate"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "dependsOn": [
        "^db:generate",
        "@workspace/database#build"
      ],
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": [
        "^db:generate",
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "dev:infra": {
      "cache": false
    },
    "db:generate": {
      "outputs": [
        "generated/**"
      ],
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    }
  }
}
