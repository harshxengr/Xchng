{
  "name": "engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/worker.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint not configured for engine'"
  },
  "dependencies": {
    "@workspace/shared": "workspace:*",
    "ioredis": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@workspace/typescript-config": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
