# neon database url
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xchng"
REDIS_URL="redis://localhost:6379"

# better auth
BETTER_AUTH_SECRET=your-super-secret-32-char-minimum-key
BETTER_AUTH_URL=http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# Order API (apps/api-server): defaults shown below
PORT=4000
WS_PORT=4001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Market maker
MM_MARKETS=TATA_INR
MM_LOOP_INTERVAL_MS=8000
MM_LEVELS=3
MM_BASE_PRICE=100
MM_BASE_QUANTITY=2
MM_SPREAD_BPS=50
MM_LEVEL_SPACING_BPS=25
MM_REPRICE_TOLERANCE_BPS=15
MM_JITTER_BPS=8
MM_TARGET_BASE_RATIO=0.5
MM_MAX_INVENTORY_SKEW_BPS=40

# Comma-separated emails allowed to access operator pages
OPERATOR_EMAILS=admin@example.com
