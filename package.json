{
  "name": "xchng",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -- turbo run dev",
    "dev:infra": "docker-compose up -d",
    "dev:db": "dotenv -- turbo run db:push db:generate",
    "dev:start": "pnpm dev:infra && pnpm dev:db",
    "dev:stop": "docker-compose down && pkill -f 'tsx watch' && pkill -f 'next dev'",
    "build": "dotenv -- turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.4.4"
  },
  "packageManager": "pnpm@10.33.0"
}
