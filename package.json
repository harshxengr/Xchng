{
  "name": "xchng",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -- turbo run dev",
    "dev:infra": "docker compose up -d",
    "dev:db": "dotenv -- turbo run db:push db:generate",
    "dev:start": "pnpm dev:infra && pnpm dev:db",
    "dev:stop": "docker compose down; pkill -f '[t]sx.*watch' || true; pkill -f '[n]ext dev' || true; pkill -f '[t]urbo run dev' || true",
    "build": "dotenv -- turbo run build",
    "start": "dotenv -- turbo run start",
    "lint": "turbo run lint",
    "check-types": "dotenv -- turbo run check-types"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@10.33.2"
}
